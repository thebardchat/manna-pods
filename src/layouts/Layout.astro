  <meta property="og:type" content="website"/>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23060d1a'/%3E%3Cellipse cx='16' cy='16' rx='10' ry='7' fill='none' stroke='%234d9fff' stroke-width='1.5'/%3E%3Ccircle cx='16' cy='16' r='2' fill='%234d9fff'/%3E%3C/svg%3E"/>
</head>
<body>
  <slot/>
